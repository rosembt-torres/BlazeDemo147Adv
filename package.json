{
  "name": "blazedemo147adv",
  "version": "1.0.0",
  "description": "Projeto de automação web com Playwright",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:bdd": "cucumber-js features/**/*.feature --require steps/**/*.steps.js --require support/**/*.js --format json:reports/cucumber-report.json",
    "test:bdd:headed": "cross-env HEADLES=false npm run test:bdd",
    "report": " node generate-report.js"
  },
  "keywords": [
    "playwright",
    "cucumber"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "cross-env": "^10.1.0",
    "cucumber-html-reporter": "^7.2.0"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.7.0"
  }
}
